# Evolution API — configurações de ambiente
# Copie este arquivo para .env e preencha os valores

# URL pública do servidor (sem barra no final)
EVOLUTION_SERVER_URL=https://evolution.sipen.com.br

# Chave de autenticação da API — use uma string longa e aleatória
# Gere com: openssl rand -hex 32
EVOLUTION_API_KEY=TROQUE_ESTA_CHAVE_POR_UMA_ALEATORIA_LONGA

# PostgreSQL
POSTGRES_USER=evolution
POSTGRES_PASSWORD=TROQUE_ESTA_SENHA
POSTGRES_DB=evolution
